<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UsageTracker.ViewModels"
        x:Class="UsageTracker.Views.LoginView"
        x:DataType="vm:LoginViewModel"
        Title="Usage Tracker"
        Width="420" Height="380"
        Background="#0D0F18"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#131625"/>
            <Setter Property="BorderBrush" Value="#1E2238"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Foreground" Value="#EEF0FA"/>
            <Setter Property="CaretBrush" Value="#7C6BF8"/>
            <Setter Property="SelectionBrush" Value="#3A336B"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="FontSize" Value="13.5"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#2D3254"/>
        </Style>
        <Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#7C6BF8"/>
        </Style>
        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="#3E4260"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#7C6BF8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#6A58E8"/>
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#5849D2"/>
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2D2A4A"/>
        </Style>

    </Window.Styles>

    <Grid RowDefinitions="36,*">

        <!-- Drag region -->
        <Border Grid.Row="0"
                Background="Transparent"
                PointerPressed="OnTitleBarPointerPressed"/>

        <!-- Form card -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    Margin="52,0,52,24"
                    Spacing="0">

            <!-- Logo mark -->
            <Border Width="46" Height="46"
                    CornerRadius="12"
                    Background="#131625"
                    BorderBrush="#1E2238"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
                <TextBlock Text="Ut"
                           Foreground="#7C6BF8"
                           FontSize="17"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Title -->
            <TextBlock Text="Usage Tracker"
                       Foreground="#EEF0FA"
                       FontSize="19"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <!-- Subtitle -->
            <TextBlock Text="Sign in to your account"
                       Foreground="#3E4260"
                       FontSize="12.5"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,28"/>

            <!-- Email -->
            <TextBox Watermark="Email address"
                     Text="{Binding Email}"
                     Margin="0,0,0,10"/>

            <!-- Password -->
            <TextBox Watermark="Password"
                     PasswordChar="●"
                     Text="{Binding Password}"
                     Margin="0,0,0,12"/>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#F87171"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Sign in button -->
            <Button Content="Sign in"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Classes="primary"
                    HorizontalAlignment="Stretch"/>

        </StackPanel>

    </Grid>

</Window>
